# ==============================================================================
# UAE Commercial Property Classifier — .gitignore
# ==============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# --- Virtual environments ---
venv/
.venv/
env/
.env/
ENV/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_*

# --- Data & models ---
data/raw/*
data/processed/*
data/results/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/results/.gitkeep
models/*
!models/.gitkeep

# --- Logs & outputs ---
*.log
logs/
output/

# --- OS files ---
Thumbs.db
Desktop.ini

# --- Environment ---
.env
*.env.local

# --- Diagnostics ---
profile*
*.prof

# --- Coverage ---
.coverage
.coverage.*
htmlcov/
coverage.xml
